# Copy to .env and adjust paths. Never commit .env.

# Option A — full data tree on the SSD (raw/processed/embeddings/...)
# Uses subfolders: raw, processed, embeddings, splits, external, vggface2
# FACE_DATA_ROOT=/Volumes/HIKSEMI/face_access_data

# Option B — flash volume + folder name (default if FACE_DATA_ROOT is unset)
FACE_FLASH_ROOT=/Volumes/HIKSEMI
FACE_DATA_FOLDER=face_access_data

# Train classifier on processed crops. Defaults to <DATA_ROOT>/processed.
# Point this at your SSD split if images are already cropped, e.g.:
# FACE_TRAIN_PROCESSED_DIR=/Volumes/HIKSEMI/train
